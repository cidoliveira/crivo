# Database connection URL (PostgreSQL with asyncpg driver)
# For local development: postgresql+asyncpg://user:password@localhost:5432/autou
# For Render/Neon: the postgres:// format is auto-converted to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Hugging Face API key for inference
# Get yours at: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_token_here

# Comma-separated or JSON list of allowed CORS origins
# For local development: ["http://localhost:3000"]
# For production: add your Vercel deployment URL
ALLOWED_ORIGINS=["http://localhost:3000"]
